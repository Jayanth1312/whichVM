PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=whichvm

# Provider Pricing API Keys
CLOUDPRICE_AWS_KEY=your_aws_cloudprice_api_key
CLOUDPRICE_AZURE_KEY=your_azure_cloudprice_api_key
CLOUDPRICE_GCP_KEY=your_gcp_cloudprice_api_key

# Vercel Blob Storage & CDN
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx
BLOB_CDN_URL=https://xxxx.public.blob.vercel-storage.com

# Cron Header Secret
CRON_SECRET=your_cron_secret
